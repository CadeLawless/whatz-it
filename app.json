{
  "expo": {
    "name": "WHATZ IT",
    "slug": "whatz-it",
    "version": "0.1.0",
    "orientation": "default",
    "icon": "./assets/images/icon.png",
    "scheme": "whatzit",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.cadelawless.whatzit",
      "supportsTablet": true,
      "requireFullScreen": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.cadelawless.whatzit",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-dev-client",
      [
        "expo-sensors",
        {
          "motionPermission": "Allow WHATZ IT to detect correct and passed cards when you tilt your device."
        }
      ],
      [
        "expo-screen-orientation",
        {
          "initialOrientation": "PORTRAIT"
        }
      ],
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F7F5EF",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 76
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Allow WHATZ IT to record the clues and reactions during a round.",
          "recordAudioAndroid": true
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow WHATZ IT to record the clue-givers during a round.",
          "microphonePermission": "Allow WHATZ IT to record the clues and reactions during a round.",
          "recordAudioAndroid": true,
          "barcodeScannerEnabled": false
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": false,
          "savePhotosPermission": "Allow WHATZ IT to save a round video when you tap Save Video.",
          "granularPermissions": [
            "video"
          ]
        }
      ],
      "expo-video"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "cf398c79-0059-415d-ae00-d39b864561d5"
      }
    },
    "owner": "cadelawless"
  }
}
