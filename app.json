{
  "expo": {
    "name": "WHATZ IT?",
    "slug": "whatz-it",
    "owner": "cader-taders-team",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/images/whatz-it-app-icon.png",
    "scheme": "whatzit",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/whatz-it-app-icon.png",
      "bundleIdentifier": "com.cadelawless.whatzit",
      "supportsTablet": true,
      "requireFullScreen": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Allow WHATZ IT? to record the clue-givers during a round.",
        "NSMicrophoneUsageDescription": "Allow WHATZ IT? to record the clues and reactions during a round."
      },
      "privacyManifests": {
        "NSPrivacyTracking": false,
        "NSPrivacyTrackingDomains": [],
        "NSPrivacyCollectedDataTypes": [],
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryFileTimestamp",
            "NSPrivacyAccessedAPITypeReasons": [
              "C617.1"
            ]
          }
        ]
      }
    },
    "android": {
      "package": "com.cadelawless.whatzit",
      "icon": "./assets/images/whatz-it-app-icon.png",
      "adaptiveIcon": {
        "backgroundColor": "#4BCBFD",
        "foregroundImage": "./assets/images/whatz-it-app-icon.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_VIDEO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-dev-client",
      [
        "expo-sensors",
        {
          "motionPermission": "Allow WHATZ IT? to detect correct and passed cards when you tilt your device."
        }
      ],
      [
        "expo-screen-orientation",
        {
          "initialOrientation": "PORTRAIT"
        }
      ],
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#4BCBFD",
          "image": "./assets/images/branding/albert-headshot.png",
          "imageWidth": 152
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Allow WHATZ IT? to record the clues and reactions during a round.",
          "recordAudioAndroid": true,
          "enableBackgroundPlayback": false,
          "enableBackgroundRecording": false
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": false,
          "savePhotosPermission": "Allow WHATZ IT? to save a round video when you tap Save Video.",
          "granularPermissions": [
            "video"
          ]
        }
      ],
      "expo-video",
      "expo-image",
      "expo-status-bar",
      "expo-web-browser",
      "expo-asset",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "87757e5a-760d-4d13-b62e-fcfe82a87728"
      }
    }
  }
}
