{
  "$schema": "https://nitro.margelo.com/nitro.schema.json",
  "cxxNamespace": ["whatzit", "liveoverlay"],
  "ios": {
    "iosModuleName": "WhatzItLiveOverlay"
  },
  "android": {
    "androidNamespace": ["whatzit", "liveoverlay"],
    "androidCxxLibName": "WhatzItLiveOverlay"
  },
  "autolinking": {
    "LiveOverlayOutputFactory": {
      "ios": {
        "language": "swift",
        "implementationClassName": "HybridLiveOverlayOutputFactory"
      },
      "android": {
        "language": "kotlin",
        "implementationClassName": "HybridLiveOverlayOutputFactory"
      }
    }
  },
  "ignorePaths": ["**/node_modules"],
  "gitAttributesGeneratedFlag": true
}
